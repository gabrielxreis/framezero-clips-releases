@echo off
setlocal EnableExtensions
title Desinstalar FrameZero Completo v1.0.63
color 0C
cls
echo ============================================================
echo       DESINSTALACAO COMPLETA - FRAMEZERO v1.0.63
echo ============================================================
echo.
echo Isto remove FrameZero Clips, Nations, atalhos, caches,
echo plugins Aitum, VB-Audio/VB-CABLE, configs e ZERA as
echo configuracoes do OBS do usuario.
echo.
echo ATENCAO: o OBS nao sera desinstalado, mas vai abrir como novo,
echo sem perfis, cenas, docks e configuracoes anteriores.
echo.
set /p CONFIRMA="Digite APAGAR para confirmar: "
if /i not "%CONFIRMA%"=="APAGAR" exit /b 0
echo.
echo Executando limpeza completa como administrador...
powershell -NoProfile -ExecutionPolicy Bypass -Command "$b=''; $p=Join-Path $env:TEMP 'FrameZero_Full_Uninstall_Windows_v1.0.63.ps1'; [IO.File]::WriteAllBytes($p,[Convert]::FromBase64String($b)); Start-Process -FilePath 'powershell.exe' -Verb RunAs -Wait -ArgumentList @('-NoProfile','-ExecutionPolicy','Bypass','-File', $p)"
set "RC=%ERRORLEVEL%"
echo.
if not "%RC%"=="0" (
  echo [AVISO] O PowerShell retornou codigo %RC%, mas a limpeza foi tentada.
) else (
  echo [OK] FrameZero removido por completo.
)
echo.
pause
exit /b 0
